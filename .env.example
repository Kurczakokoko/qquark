# qquark Environment Configuration
# Copy this file to .env.local for local development

# PartyKit / Realtime (when we wire the relay)
# PARTYKIT_HOST=your-party.yourname.partykit.dev
# NEXT_PUBLIC_PARTYKIT_HOST=your-party.yourname.partykit.dev

# Connector session settings (future)
# CONNECTOR_SESSION_TTL_MINUTES=45

# Optional: Enable more verbose logging during connector development
# NEXT_PUBLIC_DEBUG_CONNECTOR=true
